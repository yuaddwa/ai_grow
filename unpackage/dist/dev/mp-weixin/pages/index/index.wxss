  border: 1rpx solid rgba(79,172,254,0.15);
}
.quick-pill.data-v-1cf27b2a:active { background: #d4ecff; transform: scale(0.96);
}

/* 输入栏 */
.input-card.data-v-1cf27b2a {
  background: #fff; border-radius: 18rpx;
  padding: 16rpx 18rpx 20rpx; margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(79,172,254,0.08);
}
.inp.data-v-1cf27b2a { font-size: 26rpx; color: #333; padding-bottom: 14rpx;
}
.inp-ph.data-v-1cf27b2a { color: #b8d8f0; font-size: 24rpx;
}
