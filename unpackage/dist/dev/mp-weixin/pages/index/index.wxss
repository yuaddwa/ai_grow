.user-txt.data-v-1cf27b2a { font-size: 27rpx; color: #fff; line-height: 1.7; word-break: break-all;
}
.user-avatar.data-v-1cf27b2a {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8f4fd, #d4ecff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(79,172,254,0.12);
}
.user-avatar-img.data-v-1cf27b2a {
  width: 100%;
  height: 100%;
}
.card-hd.data-v-1cf27b2a { display: block; font-size: 26rpx; color: #333; line-height: 1.6; margin-bottom: 6rpx;
}
.plan-row.data-v-1cf27b2a { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #eef5fb;
}
.plan-row.data-v-1cf27b2a:last-of-type { border-bottom: none;
}
.plan-l.data-v-1cf27b2a { display: flex; align-items: center; gap: 10rpx;
}
.plan-nm.data-v-1cf27b2a { font-size: 26rpx; color: #333;
}
.plan-tm.data-v-1cf27b2a { font-size: 24rpx; color: #99c4e8;
}
.link-row.data-v-1cf27b2a { text-align: right; margin-top: 8rpx;
}
