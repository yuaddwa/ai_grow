
.tasks-page.data-v-027feebf {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fd 0%, #f0f7ff 40%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

/* 动态气泡 */
.bg-bubbles.data-v-027feebf {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0; overflow: hidden;
}
.bubble.data-v-027feebf { position: absolute; border-radius: 50%; opacity: 0.1;
}
.b1.data-v-027feebf { width: 200rpx; height: 200rpx; background: #4facfe; top: -40rpx; right: -30rpx; animation: float1-027feebf 7s ease-in-out infinite;
}
.b2.data-v-027feebf { width: 140rpx; height: 140rpx; background: #00f2fe; top: 260rpx; left: -40rpx; animation: float2-027feebf 9s ease-in-out infinite;
}
.b3.data-v-027feebf { width: 100rpx; height: 100rpx; background: #a8d8ff; bottom: 400rpx; right: 50rpx; animation: float3-027feebf 8s ease-in-out infinite;
}
.b4.data-v-027feebf { width: 160rpx; height: 160rpx; background: #6cb4ee; bottom: 80rpx; left: -30rpx; animation: float1-027feebf 10s ease-in-out infinite;
}
.b5.data-v-027feebf { width: 70rpx; height: 70rpx; background: #74b9ff; top: 50%; left: 65%; animation: float2-027feebf 6s ease-in-out infinite;
}
@keyframes float1-027feebf {
0%,100% { transform: translateY(0) scale(1);
}
50% { transform: translateY(-30rpx) scale(1.05);
}
}
@keyframes float2-027feebf {
0%,100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(25rpx) translateX(15rpx);
}
}
@keyframes float3-027feebf {
0%,100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(-20rpx) translateX(-15rpx);
}
}

/* 返回按钮 */
.back-btn.data-v-027feebf {
  position: absolute; top: 100rpx; left: 32rpx; z-index: 10;
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: rgba(255,255,255,0.7);
  display: flex; align-items: center; justify-content: center;
}

/* 头部 */
.header.data-v-027feebf {
  position: relative; z-index: 1;
  padding: 120rpx 48rpx 20rpx 112rpx;
  opacity: 0; transform: translateY(30rpx);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}
.header.show.data-v-027feebf { opacity: 1; transform: translateY(0);
}
.title.data-v-027feebf { display: block; font-size: 48rpx; font-weight: 800; color: #222; letter-spacing: 2rpx;
}
.subtitle.data-v-027feebf { display: block; font-size: 26rpx; color: #888; margin-top: 8rpx;
}

/* 筛选 tab */
.tab-bar.data-v-027feebf {
  position: relative; z-index: 1;
  display: flex; gap: 16rpx; padding: 20rpx 48rpx;
  opacity: 0; transition: opacity 0.6s ease-out 0.15s;
}
.tab-bar.show.data-v-027feebf { opacity: 1;
}
.tab-pill.data-v-027feebf {
  padding: 12rpx 28rpx; border-radius: 24rpx;
  background: rgba(255,255,255,0.7); border: 1rpx solid rgba(79,172,254,0.12);
  font-size: 24rpx; color: #888; transition: all 0.3s;
}
.tab-pill.active.data-v-027feebf {
  background: linear-gradient(135deg, #4facfe, #6cb4ee);
  color: #fff; border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(79,172,254,0.3);
}

/* 任务列表 */
.task-scroll.data-v-027feebf {
  position: relative; z-index: 1;
  flex: 1; height: calc(100vh - 340rpx); padding: 10rpx 32rpx;
}

/* 空状态 */
.empty-state.data-v-027feebf {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 160rpx; gap: 16rpx;
}
.empty-text.data-v-027feebf { font-size: 30rpx; color: #aaa; font-weight: 600;
}
.empty-sub.data-v-027feebf { font-size: 24rpx; color: #ccc;
}

/* 任务卡片 */
.task-card.data-v-027feebf {
  display: flex; gap: 20rpx; padding: 28rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(79,172,254,0.06);
  border: 1rpx solid rgba(255,255,255,0.6);
  opacity: 0; transform: translateY(20rpx);
  transition: opacity 0.4s ease-out, transform 0.4s ease-out;
}
.task-card.show.data-v-027feebf { opacity: 1; transform: translateY(0);
}
.task-card.data-v-027feebf:active { transform: scale(0.98);
}
.task-left.data-v-027feebf { flex-shrink: 0; padding-top: 8rpx;
}
.task-status-dot.data-v-027feebf {
  width: 16rpx; height: 16rpx; border-radius: 50%;
}
.task-status-dot.open.data-v-027feebf { background: #4facfe;
}
.task-status-dot.done.data-v-027feebf { background: #6bcb77;
}
.task-status-dot.cancelled.data-v-027feebf { background: #ccc;
}
.task-body.data-v-027feebf { flex: 1; min-width: 0;
}
.task-title.data-v-027feebf {
  display: block; font-size: 28rpx; font-weight: 600; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.task-desc.data-v-027feebf {
  display: block; font-size: 24rpx; color: #999; margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.task-meta.data-v-027feebf {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 12rpx;
}
.meta-item.data-v-027feebf { display: flex; align-items: center; gap: 6rpx;
}
.meta-text.data-v-027feebf { font-size: 22rpx; color: #99c4e8;
}
.task-tag.data-v-027feebf {
  padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 20rpx;
}
.task-tag.open.data-v-027feebf { background: rgba(79,172,254,0.1); color: #4facfe;
}
.task-tag.done.data-v-027feebf { background: rgba(107,203,119,0.1); color: #6bcb77;
}
.task-tag.cancelled.data-v-027feebf { background: rgba(200,200,200,0.2); color: #aaa;
}
