}
.rec-row.data-v-1cf27b2a { padding: 12rpx 0; border-bottom: 1rpx solid #eef5fb;
}
.rec-row.data-v-1cf27b2a:last-child { border-bottom: none;
}
.rec-txt.data-v-1cf27b2a { font-size: 24rpx; color: #555;
}

/* 数据统计卡片 */
.stats-grid.data-v-1cf27b2a {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 10rpx;
}
.stat-item.data-v-1cf27b2a {
  background: linear-gradient(135deg, #e8f4fd, #f0f7ff);
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}
.stat-value.data-v-1cf27b2a {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #4facfe;
}
.stat-label.data-v-1cf27b2a {
  display: block;
  font-size: 20rpx;
  color: #99c4e8;
  margin-top: 4rpx;
}

/* 快捷标签 */
.quick-bar.data-v-1cf27b2a { display: flex; gap: 12rpx; padding: 0 24rpx; margin-bottom: 8rpx;
}
.quick-pill.data-v-1cf27b2a {
  background: linear-gradient(135deg, #e8f4fd, #f0f7ff);
  font-size: 22rpx; color: #4a8cc7;
