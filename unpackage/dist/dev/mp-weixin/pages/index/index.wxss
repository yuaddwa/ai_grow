
page.data-v-1cf27b2a { background: linear-gradient(180deg, #e8f4fd 0%, #f0f7ff 40%, #ffffff 100%);
}
.page.data-v-1cf27b2a {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #e8f4fd 0%, #f0f7ff 40%, #ffffff 100%);
  padding-top: 100rpx;
  box-sizing: border-box;
}

/* 动画 */
@keyframes pulse-1cf27b2a {
0%,100% { opacity:1;
}
50% { opacity:0.5;
}
}
.banner.show.data-v-1cf27b2a { opacity: 1; transform: translateY(0);
}
.func-bar.show.data-v-1cf27b2a { opacity: 1; transform: translateY(0);
}
.msg-item.show.data-v-1cf27b2a { opacity: 1; transform: scale(1) translateY(0);
}

/* Banner */
.banner.data-v-1cf27b2a {
  background: linear-gradient(135deg, #4facfe 0%, #6cb4ee 50%, #a8d8ff 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin: 0 24rpx 14rpx;
  opacity: 0;
  transform: translateY(-24rpx);
  transition: opacity 0.45s ease-out, transform 0.45s ease-out;
}
.banner-row.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.robot.data-v-1cf27b2a {
  flex-shrink: 0;
}
.plan-entry.data-v-1cf27b2a {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255,255,255,0.25);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-left: auto;
  position: relative;
}
.plan-entry-txt.data-v-1cf27b2a {
  font-size: 22rpx;
  color: #fff;
}
.badge.data-v-1cf27b2a {
  position: absolute;
  top: -8rpx; right: -8rpx;
  min-width: 28rpx; height: 28rpx;
  border-radius: 14rpx;
  background: #ff4757;
  display: flex; align-items: center; justify-content: center;
  padding: 0 6rpx;
}
.badge-text.data-v-1cf27b2a {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}
.banner-texts.data-v-1cf27b2a { flex: 1;
}
.banner-title.data-v-1cf27b2a { display: block; color: #fff; font-size: 32rpx; font-weight: bold;
}
.banner-sub.data-v-1cf27b2a { display: block; color: rgba(255,255,255,0.8); font-size: 22rpx; margin-top: 4rpx;
}

/* 功能标签 */
.func-bar.data-v-1cf27b2a {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 12rpx;
  opacity: 0;
  transform: translateY(32rpx);
  transition: opacity 0.45s ease-out 0.12s, transform 0.45s ease-out 0.12s;
  flex-wrap: wrap;
}
.func-pill.data-v-1cf27b2a {
  background: linear-gradient(135deg, #e8f4fd, #f0f7ff);
  font-size: 22rpx;
  color: #4a8cc7;
  padding: 10rpx 18rpx;
  border-radius: 22rpx;
  transition: all 0.15s;
  border: 1rpx solid rgba(79,172,254,0.15);
}
.func-pill.data-v-1cf27b2a:active {
  background: #d4ecff;
  transform: scale(0.96);
}

/* 聊天 */
.chat-scroll.data-v-1cf27b2a { flex: 1; padding: 0 24rpx; overflow: hidden;
}
.msg-list.data-v-1cf27b2a { padding-bottom: 14rpx;
}
.msg-item.data-v-1cf27b2a {
  margin-bottom: 14rpx;
  opacity: 0;
  transform: scale(0.94) translateY(12rpx);
  transition: opacity 0.3s ease-out, transform 0.3s ease-out;
}
.align-left.data-v-1cf27b2a { display: flex; justify-content: flex-start; align-items: flex-start; gap: 12rpx;
}
.align-right.data-v-1cf27b2a { display: flex; justify-content: flex-end;
}
.card-ai.data-v-1cf27b2a {
