
.notify-page.data-v-e30a2353 {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5e6 0%, #fff8f0 30%, #ffffff 100%);
  position: relative; overflow: hidden;
}

/* 动态气泡 */
.bg-bubbles.data-v-e30a2353 { position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 0; overflow: hidden;
}
.bubble.data-v-e30a2353 { position: absolute; border-radius: 50%; opacity: 0.08;
}
.b1.data-v-e30a2353 { width: 200rpx; height: 200rpx; background: #ffa500; top: -40rpx; right: -30rpx; animation: float1-e30a2353 7s ease-in-out infinite;
}
.b2.data-v-e30a2353 { width: 140rpx; height: 140rpx; background: #ffb74d; top: 260rpx; left: -40rpx; animation: float2-e30a2353 9s ease-in-out infinite;
}
.b3.data-v-e30a2353 { width: 100rpx; height: 100rpx; background: #ffcc80; bottom: 400rpx; right: 50rpx; animation: float3-e30a2353 8s ease-in-out infinite;
}
.b4.data-v-e30a2353 { width: 160rpx; height: 160rpx; background: #ff9800; bottom: 80rpx; left: -30rpx; animation: float1-e30a2353 10s ease-in-out infinite;
}
.b5.data-v-e30a2353 { width: 70rpx; height: 70rpx; background: #ffe0b2; top: 50%; left: 65%; animation: float2-e30a2353 6s ease-in-out infinite;
}
@keyframes float1-e30a2353 {
0%,100% { transform: translateY(0) scale(1);
}
50% { transform: translateY(-30rpx) scale(1.05);
}
}
@keyframes float2-e30a2353 {
0%,100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(25rpx) translateX(15rpx);
}
}
@keyframes float3-e30a2353 {
0%,100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(-20rpx) translateX(-15rpx);
}
}

/* 返回按钮 */
.back-btn.data-v-e30a2353 {
  position: absolute; top: 100rpx; left: 32rpx; z-index: 10;
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: rgba(255,255,255,0.7);
  display: flex; align-items: center; justify-content: center;
}

/* 头部 */
.header.data-v-e30a2353 {
  position: relative; z-index: 1;
  padding: 120rpx 48rpx 20rpx 112rpx;
  opacity: 0; transform: translateY(30rpx);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}
.header.show.data-v-e30a2353 { opacity: 1; transform: translateY(0);
}
.header-row.data-v-e30a2353 { display: flex; align-items: flex-start; justify-content: space-between;
}
.title.data-v-e30a2353 { display: block; font-size: 48rpx; font-weight: 800; color: #222; letter-spacing: 2rpx;
}
.subtitle.data-v-e30a2353 { display: block; font-size: 26rpx; color: #888; margin-top: 8rpx;
}
.read-all-btn.data-v-e30a2353 {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 24rpx; border-radius: 24rpx;
  background: rgba(79,172,254,0.08); margin-top: 12rpx;
  transition: all 0.3s;
}
.read-all-btn.data-v-e30a2353:active { transform: scale(0.95);
}
.read-all-btn text.data-v-e30a2353 { font-size: 22rpx; color: #4facfe;
}

/* 通知列表 */
.notify-scroll.data-v-e30a2353 {
  position: relative; z-index: 1;
  flex: 1; height: calc(100vh - 280rpx); padding: 10rpx 32rpx;
}

/* 空状态 */
.empty-state.data-v-e30a2353 {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 160rpx; gap: 16rpx;
}
.empty-text.data-v-e30a2353 { font-size: 30rpx; color: #aaa; font-weight: 600;
}
.empty-sub.data-v-e30a2353 { font-size: 24rpx; color: #ccc;
}

/* 通知卡片 */
.notify-card.data-v-e30a2353 {
  display: flex; gap: 16rpx; padding: 24rpx; position: relative;
  background: rgba(255,255,255,0.92);
  border-radius: 20rpx; margin-bottom: 14rpx;
  box-shadow: 0 2rpx 16rpx rgba(255,165,0,0.05);
  border: 1rpx solid rgba(255,255,255,0.6);
  opacity: 0; transform: translateY(16rpx);
  transition: opacity 0.35s ease-out, transform 0.35s ease-out;
  transition: transform 0.2s;
}
.notify-card.data-v-e30a2353:active { transform: scale(0.98);
}
.notify-card.unread.data-v-e30a2353 {
  border-left: 6rpx solid #ffa500;
}
@keyframes fadeInUp-e30a2353 {
from { opacity: 0; transform: translateY(16rpx);
}
to { opacity: 1; transform: translateY(0);
}
}
.notify-dot.data-v-e30a2353 {
  position: absolute; top: 20rpx; right: 20rpx;
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: #ffa500;
}
.notify-icon.data-v-e30a2353 {
  flex-shrink: 0; width: 52rpx; height: 52rpx;
  border-radius: 16rpx; display: flex;
  align-items: center; justify-content: center;
}
.icon-task.data-v-e30a2353 { background: rgba(255,165,0,0.1); color: #ffa500;
}
.icon-info.data-v-e30a2353 { background: rgba(79,172,254,0.1); color: #4facfe;
}
.notify-body.data-v-e30a2353 { flex: 1; min-width: 0;
}
.notify-title.data-v-e30a2353 {
  display: block; font-size: 28rpx; font-weight: 600; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.notify-text.data-v-e30a2353 {
  display: block; font-size: 24rpx; color: #888; margin-top: 6rpx;
  line-height: 1.6; overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.notify-time.data-v-e30a2353 { display: block; font-size: 20rpx; color: #ccc; margin-top: 8rpx;
}
