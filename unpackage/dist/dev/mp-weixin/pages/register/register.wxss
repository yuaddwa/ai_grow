
.register-page.data-v-bac4a35d {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0e6ff 0%, #e0ecff 30%, #e8f4fd 60%, #f0f7ff 100%);
  position: relative;
  overflow: hidden;
}

/* 动态气泡背景 */
.bg-bubbles.data-v-bac4a35d {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
  overflow: hidden;
}
.bubble.data-v-bac4a35d {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
}
.b1.data-v-bac4a35d {
  width: 280rpx; height: 280rpx;
  background: #7b6df0;
  top: -60rpx; right: -40rpx;
  animation: float1-bac4a35d 6s ease-in-out infinite;
}
.b2.data-v-bac4a35d {
  width: 180rpx; height: 180rpx;
  background: #4facfe;
  top: 180rpx; left: -30rpx;
  animation: float2-bac4a35d 8s ease-in-out infinite;
}
.b3.data-v-bac4a35d {
  width: 140rpx; height: 140rpx;
  background: #a8d8ff;
  bottom: 350rpx; right: 60rpx;
  animation: float3-bac4a35d 7s ease-in-out infinite;
}
.b4.data-v-bac4a35d {
  width: 100rpx; height: 100rpx;
  background: #89f7fe;
  bottom: 120rpx; left: 80rpx;
  animation: float1-bac4a35d 9s ease-in-out infinite;
}
.b5.data-v-bac4a35d {
  width: 70rpx; height: 70rpx;
  background: #c3b8ff;
  top: 45%; left: 60%;
  animation: float2-bac4a35d 5s ease-in-out infinite;
}
@keyframes float1-bac4a35d {
0%, 100% { transform: translateY(0) scale(1);
}
50% { transform: translateY(-40rpx) scale(1.05);
}
}
@keyframes float2-bac4a35d {
0%, 100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(30rpx) translateX(20rpx);
}
}
@keyframes float3-bac4a35d {
0%, 100% { transform: translateY(0) translateX(0);
}
50% { transform: translateY(-20rpx) translateX(-30rpx);
}
}

/* 返回按钮 */
.back-btn.data-v-bac4a35d {
  position: absolute;
  top: 100rpx;
  left: 32rpx;
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 内容入场动画 */
@keyframes slideUp-bac4a35d {
from { opacity: 0; transform: translateY(60rpx);
}
to { opacity: 1; transform: translateY(0);
}
}
.content.data-v-bac4a35d {
  position: relative;
  z-index: 1;
  padding: 180rpx 48rpx 60rpx;
  opacity: 0;
}
.content.show.data-v-bac4a35d {
  animation: slideUp-bac4a35d 0.6s ease-out both;
}
.title-area.data-v-bac4a35d {
  margin-bottom: 50rpx;
}
.title.data-v-bac4a35d {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #222;
  letter-spacing: 2rpx;
}
.subtitle.data-v-bac4a35d {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
}

/* 表单卡片 */
.form-card.data-v-bac4a35d {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(123, 109, 240, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}
.input-group.data-v-bac4a35d {
  display: flex;
  align-items: center;
  background: #f5f3ff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}
.code-group.data-v-bac4a35d {
  padding-right: 8rpx;
}
.input-icon.data-v-bac4a35d {
  flex-shrink: 0;
  margin-right: 16rpx;
}
.form-input.data-v-bac4a35d {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 96rpx;
}
.ph.data-v-bac4a35d {
  color: #c8c0f0;
}
.toggle-pw.data-v-bac4a35d {
  flex-shrink: 0;
  padding: 8rpx;
}
.btn-code.data-v-bac4a35d {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #7b6df0;
  background: none;
  border: none;
  padding: 0 20rpx;
  margin: 0;
  line-height: 1.4;
  border-left: 1rpx solid #e8e4f8;
  margin-left: 12rpx;
  padding-left: 20rpx;
  transition: color 0.3s;
}
.btn-code.data-v-bac4a35d::after {
  border: none;
}
.btn-code.disabled.data-v-bac4a35d {
  color: #ccc;
}
.btn-register.data-v-bac4a35d {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #d8d0f0, #e0daf0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 48rpx;
  margin-top: 8rpx;
  transition: all 0.3s;
  box-shadow: none;
}
.btn-register.active.data-v-bac4a35d {
  background: linear-gradient(135deg, #7b6df0, #a18cd1);
  box-shadow: 0 8rpx 24rpx rgba(123, 109, 240, 0.3);
}
.btn-register.data-v-bac4a35d::after {
  border: none;
}
.btn-text.data-v-bac4a35d {
  letter-spacing: 8rpx;
}

/* 底部 */
.bottom-area.data-v-bac4a35d {
  text-align: center;
  margin-top: 48rpx;
}
.bottom-text.data-v-bac4a35d {
  font-size: 26rpx;
  color: #999;
}
.bottom-link.data-v-bac4a35d {
  font-size: 26rpx;
  color: #7b6df0;
  font-weight: 600;
  margin-left: 8rpx;
}
.agreement.data-v-bac4a35d {
  text-align: center;
  margin-top: 32rpx;
}
.agreement text.data-v-bac4a35d {
  font-size: 20rpx;
  color: #bbb;
}
